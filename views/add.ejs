<!DOCTYPE html>
<html lang="en">
<head><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"><title>Thêm Vé</title></head>
<body class="container mt-4"><h2 class="mb-4">Thêm Vé Mới</h2>
    <% if(errors && errors.length > 0) { %><div class="alert alert-danger"><ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul></div><% } %>
    <form action="/add" method="POST" enctype="multipart/form-data" class="card p-4 shadow-sm">
        <div class="row mb-3"><div class="col"><input type="text" name="eventName" class="form-control" placeholder="Tên sự kiện" value="<%= ticket.eventName || '' %>" required></div><div class="col"><input type="text" name="holderName" class="form-control" placeholder="Tên người sở hữu" value="<%= ticket.holderName || '' %>" required></div></div>
        <div class="row mb-3"><div class="col"><input type="number" name="quantity" class="form-control" placeholder="Số lượng" value="<%= ticket.quantity || '' %>" required></div><div class="col"><input type="number" name="pricePerTicket" class="form-control" placeholder="Giá vé" value="<%= ticket.pricePerTicket || '' %>" required></div><div class="col"><input type="date" name="eventDate" class="form-control" value="<%= ticket.eventDate || '' %>" required></div></div>
        <div class="row mb-3"><div class="col"><select name="category" class="form-select" required><option value="Standard" <%= ticket.category === 'Standard' ? 'selected' : '' %>>Standard</option><option value="VIP" <%= ticket.category === 'VIP' ? 'selected' : '' %>>VIP</option><option value="VVIP" <%= ticket.category === 'VVIP' ? 'selected' : '' %>>VVIP</option></select></div><div class="col"><select name="status" class="form-select" required><option value="Upcoming" <%= ticket.status === 'Upcoming' ? 'selected' : '' %>>Upcoming</option><option value="Sold" <%= ticket.status === 'Sold' ? 'selected' : '' %>>Sold</option><option value="Cancelled" <%= ticket.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option></select></div></div>
        <div class="mb-4"><label>Ảnh minh họa:</label><input type="file" name="image" class="form-control" accept="image/*"></div>
        <button type="submit" class="btn btn-primary w-100">Thêm Mới</button><a href="/" class="btn btn-secondary w-100 mt-2">Quay Lại</a>
    </form>
</body>
</html>