<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>
        <%= mode === "add" ? "Thêm Sách" : mode === "edit" ? "Sửa Sách" : "Chi Tiết Sách" %>
    </title>
</head>
<body class="container mt-4 mb-5">
    <h2 class="mb-4">
        <%= mode === "add" ? "Thêm Sách Mới" : mode === "edit" ? "Sửa Sách" : "Chi Tiết Sách" %>
    </h2>

    <% if (errors && errors.length > 0) { %>
        <div class="alert alert-danger">
            <ul class="mb-0">
                <% errors.forEach((error) => { %>
                    <li><%= error %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <% if (mode === "detail") { %>
        <div class="card p-4 shadow-sm">
            <div class="row g-3">
                <div class="col-md-4">
                    <% if (book.coverImageUrl) { %>
                        <img src="<%= book.coverImageUrl %>" class="img-fluid rounded border" alt="book-cover">
                    <% } else { %>
                        <div class="border rounded p-5 text-center text-muted">Chưa có ảnh bìa</div>
                    <% } %>
                </div>
                <div class="col-md-8">
                    <p><strong>Mã sách:</strong> <%= book.bookId %></p>
                    <p><strong>Tên sách:</strong> <%= book.title %></p>
                    <p><strong>Tác giả:</strong> <%= book.author %></p>
                    <p><strong>Thể loại:</strong> <%= book.category %></p>
                    <p><strong>Giá:</strong> <%= Number(book.price || 0).toLocaleString("vi-VN") %> đ</p>
                    <p><strong>Tồn kho:</strong> <%= book.unit_in_stock %></p>
                    <p><strong>Giá trị tồn kho:</strong> <%= Number(book.totalValue || 0).toLocaleString("vi-VN") %> đ</p>
                    <p><strong>Ngày tạo:</strong> <%= book.createdAt || "" %></p>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <a href="/edit/<%= book.bookId %>" class="btn btn-warning">Sửa</a>
                <a href="/books" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    <% } else { %>
        <form action="<%= mode === 'add' ? '/add' : '/edit/' + book.bookId %>" method="POST" enctype="multipart/form-data" class="card p-4 shadow-sm">
            <input type="hidden" name="oldCoverImageUrl" value="<%= book.coverImageUrl || '' %>">

            <div class="mb-3">
                <label class="form-label">Tiêu đề</label>
                <input type="text" name="title" class="form-control" value="<%= book.title || '' %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Tác giả</label>
                <input type="text" name="author" class="form-control" value="<%= book.author || '' %>" required>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Thể loại</label>
                    <select name="category" class="form-select" required>
                        <% categories.forEach((category) => { %>
                            <option value="<%= category %>" <%= book.category === category ? 'selected' : '' %>><%= category %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Giá (đ)</label>
                    <input type="number" name="price" class="form-control" value="<%= book.price || '' %>" min="1" step="0.01" required>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Số lượng tồn kho</label>
                    <input type="number" name="unit_in_stock" class="form-control" value="<%= book.unit_in_stock || 0 %>" min="0" step="1" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Ảnh bìa</label>
                <input type="file" name="coverImage" class="form-control" accept="image/*">
                <% if (book.coverImageUrl) { %>
                    <img src="<%= book.coverImageUrl %>" width="90" class="mt-2 img-thumbnail" alt="book-cover">
                <% } %>
            </div>

            <button type="submit" class="btn <%= mode === 'add' ? 'btn-primary' : 'btn-warning' %> w-100">
                <%= mode === "add" ? "Thêm Sách" : "Cập Nhật Sách" %>
            </button>
            <a href="/books" class="btn btn-secondary w-100 mt-2">Quay lại</a>
        </form>
    <% } %>
</body>
</html>
