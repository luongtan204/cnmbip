<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Quản Lý Sách</title>
</head>
<body class="container mt-4 mb-5">
    <h2 class="mb-3">Danh Sách Sách</h2>
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
        <span>Tổng giá trị tồn kho toàn bộ nhà sách</span>
        <strong><%= Number(totalStoreValue || 0).toLocaleString("vi-VN") %> đ</strong>
    </div>

    <div class="d-flex justify-content-between mb-3 gap-3 flex-wrap">
        <form method="GET" action="/books" class="d-flex gap-2 flex-grow-1">
            <input type="text" name="search" class="form-control" placeholder="Tìm theo tên sách hoặc tác giả..." value="<%= search || '' %>">
            <button class="btn btn-primary" type="submit">Tìm kiếm</button>
        </form>
        <a href="/add" class="btn btn-success">Thêm Mới</a>
    </div>

    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Ảnh bìa</th>
                <th>Tên sách</th>
                <th>Tác giả</th>
                <th>Thể loại</th>
                <th>Giá</th>
                <th>Tồn kho</th>
                <th>Giá trị tồn kho</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% books.forEach(book => { %>
                <tr>
                    <td>
                        <% if (book.coverImageUrl) { %>
                            <img src="<%= book.coverImageUrl %>" width="60" class="img-thumbnail" alt="book-cover">
                        <% } %>
                    </td>
                    <td><%= book.title %></td>
                    <td><%= book.author %></td>
                    <td><%= book.category %></td>
                    <td><%= Number(book.price || 0).toLocaleString("vi-VN") %> đ</td>
                    <td><%= book.unit_in_stock %></td>
                    <td><%= Number(book.totalValue || 0).toLocaleString("vi-VN") %> đ</td>
                    <td class="d-flex gap-1 flex-wrap">
                        <a href="/books/<%= book.bookId %>" class="btn btn-sm btn-info">Chi tiết</a>
                        <a href="/edit/<%= book.bookId %>" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="/delete/<%= book.bookId %>" class="btn btn-sm btn-danger" onclick="return confirm('Xóa sách này?')">Xóa</a>
                    </td>
                </tr>
            <% }) %>
            <% if (books.length === 0) { %>
                <tr>
                    <td colspan="8" class="text-center">Không tìm thấy sách phù hợp.</td>
                </tr>
            <% } %>
            <tr class="table-warning">
                <td colspan="8" class="text-end fw-bold fs-5">
                    TỔNG GIÁ TRỊ TOÀN BỘ NHÀ SÁCH: <%= Number(totalStoreValue || 0).toLocaleString("vi-VN") %> VNĐ
                </td>
            </tr>
        </tbody>
    </table>
</body>
</html>